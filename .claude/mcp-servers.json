{
  "chrome-devtools": {
    "args": [
      "chrome-devtools-mcp@latest"
    ],
    "command": "npx",
    "env": {},
    "type": "stdio"
  },
  "claude-in-chrome": {
    "args": [
      "-y",
      "@anthropic-ai/claude-in-chrome-mcp@latest"
    ],
    "command": "npx",
    "type": "stdio"
  },
  "deepwiki": {
    "type": "http",
    "url": "https://deepwiki.keboola.systems/api/mcp"
  },
  "odoo-staging": {
    "type": "http",
    "url": "https://odoo-mcp-server-staging-574793647362.europe-west1.run.app/mcp"
  },
  "perplexity": {
    "args": [
      "-y",
      "@nicholasoxford/perplexity-mcp@latest"
    ],
    "command": "npx",
    "env": {
      "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
    },
    "type": "stdio"
  }
}
