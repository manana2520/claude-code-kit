# MCP Server Environment Variables
# Copy to ~/.zshrc or ~/.bashrc and fill in your values

# Perplexity API (for web search)
export PERPLEXITY_API_KEY="pplx-xxx"

# Odoo Staging OAuth (optional - only if using odoo-staging MCP)
export ODOO_STAGING_CLIENT_ID="your-google-oauth-client-id"
export ODOO_STAGING_CLIENT_SECRET="your-google-oauth-client-secret"
